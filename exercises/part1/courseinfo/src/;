import React from 'react'

const Header = (course) => {
	return (
		<h1>{course.course}</h1>
	)
}

const Part = (data) => {
	return (
		<p> {data.part} {data.exercises} </p>
	)
}

const Content = (content) => {
	return (
		<div>
			<Part part={content.content.parts[0]} exercises={content.content.exercises[0]}/>
			<Part part={content.content.parts[1]} exercises={content.content.exercises[1]}/>
			<Part part={content.content.parts[2]} exercises={content.content.exercises[2]}/>
		</div>
	)
}

const App = () => {
	const course = 'Half Stack application development'
	const part1 = 'Fundamentals of React'
	const exercises1 = 10
	const part2 = 'Using props to pass data'
	const exercises2 = 7
	const part3 = 'State of a component'
	const exercises3 = 14

	const contentObject = {
		parts: [
			part1, part2, part3
		],
		exercises: [
			exercises1, exercises2, exercises3
		]
	}

	return (
		<div>
			<Header course={course}/>
			<Content content={contentObject}/>
			<p>
				Number of exercises {exercises1 + exercises2 + exercises3}
			</p>
		</div>
	)
}

export default App
